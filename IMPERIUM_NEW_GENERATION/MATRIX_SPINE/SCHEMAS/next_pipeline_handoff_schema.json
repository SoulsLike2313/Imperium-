{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Next Pipeline Handoff Schema",
  "type": "object",
  "required": [
    "task_id",
    "target_commit_for_review",
    "base_head",
    "implementation_head",
    "closure_head",
    "final_verifier_head",
    "commit_urls",
    "changed_paths_summary",
    "primary_report_paths",
    "replay_commands",
    "servitor_claimed_efficiency_delta",
    "known_caps_or_warnings",
    "next_allowed_task_candidate"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "target_commit_for_review": {
      "type": "string"
    },
    "base_head": {
      "type": "string"
    },
    "implementation_head": {
      "type": "string"
    },
    "closure_head": {
      "type": "string"
    },
    "final_verifier_head": {
      "type": "string"
    },
    "commit_urls": {
      "type": "object",
      "required": [
        "implementation",
        "closure",
        "final_verifier"
      ],
      "properties": {
        "implementation": {
          "type": "string"
        },
        "closure": {
          "type": "string"
        },
        "final_verifier": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "changed_paths_summary": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "primary_report_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "replay_commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "servitor_claimed_efficiency_delta": {
      "type": "object",
      "required": [
        "mechanicus",
        "inquisition",
        "officio",
        "administratum",
        "overall"
      ],
      "properties": {
        "mechanicus": {
          "type": [
            "number",
            "null"
          ]
        },
        "inquisition": {
          "type": [
            "number",
            "null"
          ]
        },
        "officio": {
          "type": [
            "number",
            "null"
          ]
        },
        "administratum": {
          "type": [
            "number",
            "null"
          ]
        },
        "overall": {
          "type": [
            "number",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "known_caps_or_warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "suggested_inquisitor_review_taskpack": {
      "type": "string"
    },
    "suggested_speculum_review_taskpack": {
      "type": "string"
    },
    "next_allowed_task_candidate": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
