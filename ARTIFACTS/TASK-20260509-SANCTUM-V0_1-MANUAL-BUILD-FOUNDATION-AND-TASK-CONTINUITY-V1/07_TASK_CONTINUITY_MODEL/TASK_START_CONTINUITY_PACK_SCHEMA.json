      "type": "string"
    },
    "snapshot_time": {
      "type": "string"
    },
    "route_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "known_blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "non_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
