{
  "schema_version": "1.0.0",
  "kind": "worker_task_signal_protocol",
  "protocol_id": "WORKER_TASK_SIGNAL_PROTOCOL_V1",
  "status": "candidate",
  "truth_center": "throne_only",
  "signal_types": [
    "TASK_STARTED",
    "PHASE_STARTED",
    "PHASE_COMPLETED",
    "BLOCKED",
    "LIMIT_NEAR",
    "BUNDLE_READY",
    "HANDOFF_READY",
    "TASK_DONE"
  ],
  "required_fields": [
    "schema_version",
    "contour_id",
    "host",
    "user",
    "repo_path",
    "task_id_or_step_name",
    "phase",
    "status",
    "timestamp_utc",
    "artifact_path",
    "bundle_path",
    "next_expected_action",
    "safe_for_pc_read",
    "not_truth_center",
    "owner_attention_required",
    "limitation_notes"
  ],
  "write_path_template": "runtime/contours/signals/<contour_id>/<timestamp>_<phase>.json",
  "latest_pointer": "runtime/contours/signals/<contour_id>/LATEST_SIGNAL.json",
  "stale_signal_seconds": 900,
  "pc_interpretation": {
    "fresh": "heartbeat_visible",
    "stale": "unknown",
    "missing": "unknown"
  },
  "non_authority": [
    "not_canon_truth",
    "not_admission_signal",
    "not_push_or_autosync_control"
  ]
}
