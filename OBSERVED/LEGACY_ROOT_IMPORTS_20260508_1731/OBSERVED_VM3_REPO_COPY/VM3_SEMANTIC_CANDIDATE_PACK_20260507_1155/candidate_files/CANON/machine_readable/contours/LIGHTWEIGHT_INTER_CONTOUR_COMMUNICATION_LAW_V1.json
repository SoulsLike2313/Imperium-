{
  "schema_version": "1.0.0",
  "kind": "lightweight_inter_contour_communication_law",
  "law_id": "LIGHTWEIGHT_INTER_CONTOUR_COMMUNICATION_LAW_V1",
  "status": "candidate",
  "required_request_fields": [
    "file_pattern_or_name",
    "source_contour",
    "source_path",
    "target_contour",
    "target_path",
    "route_id",
    "hash_or_manifest_expectation",
    "purpose",
    "step_name",
    "requester_contour",
    "timestamp_utc"
  ],
  "allowed": [
    "targeted_ssh_scp_artifact_transfer",
    "bounded_lookup_in_declared_sinks",
    "formal_file_request_if_route_missing"
  ],
  "forbidden": [
    "owner_manual_file_courier_as_default",
    "broad_uncontrolled_copy",
    "endless_search_without_route_constraints",
    "path_identity_guessing"
  ],
  "stop_rule": "emit_request_and_stop_if_direct_route_unavailable"
}
