{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "WORKER_SIGNAL_SCHEMA_V1.json",
  "title": "Worker Task Signal V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contour_id",
    "host",
    "user",
    "repo_path",
    "task_id_or_step_name",
    "phase",
    "status",
    "timestamp_utc",
    "safe_for_pc_read",
    "not_truth_center",
    "owner_attention_required"
  ],
  "properties": {
    "schema_version": {
      "const": "WORKER_TASK_SIGNAL_V1"
    },
    "contour_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_\\-]+$"
    },
    "host": {
      "type": "string",
      "minLength": 1
    },
    "user": {
      "type": "string",
      "minLength": 1
    },
    "repo_path": {
      "type": "string",
      "minLength": 1
    },
    "task_id_or_step_name": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "type": "string",
      "enum": [
        "TASK_STARTED",
        "PHASE_STARTED",
        "PHASE_COMPLETED",
        "BLOCKED",
        "LIMIT_NEAR",
        "BUNDLE_READY",
        "HANDOFF_READY",
        "TASK_DONE"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "IN_PROGRESS",
        "WAITING",
        "DONE",
        "BLOCKED",
        "HANDOFF"
      ]
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "artifact_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "bundle_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "next_expected_action": {
      "type": [
        "string",
        "null"
      ]
    },
    "safe_for_pc_read": {
      "type": "boolean"
    },
    "not_truth_center": {
      "type": "boolean",
      "const": true
    },
    "owner_attention_required": {
      "type": "boolean"
    },
    "limitation_notes": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
