{
  "schema_id": "owner_comment_v0.2",
  "title": "OwnerComment",
  "description": "Schema for an Owner comment as a first-class linked object",
  "type": "object",
  "required": ["comment_id", "timestamp", "original_text", "linked_memory_zone"],
  "properties": {
    "comment_id": {"type": "string", "pattern": "^OC-[0-9]{8}-[0-9]{4}$"},
    "timestamp": {"type": "string", "format": "date-time"},
    "original_text": {"type": "string"},
    "interpreted_meaning": {"type": "string"},
    "linked_memory_zone": {"type": "string"},
    "linked_artifact_path": {"type": ["string", "null"]},
    "linked_commit": {"type": ["string", "null"]},
    "linked_task_or_stage": {"type": ["string", "null"]},
    "linked_receipt": {"type": ["string", "null"]},
    "linked_screenshot": {"type": ["string", "null"]},
    "linked_file": {"type": ["string", "null"]},
    "action_required": {"type": ["string", "null"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "needs_owner_confirmation": {"type": "boolean"},
    "tags": {"type": "array", "items": {"type": "string"}}
  }
}
