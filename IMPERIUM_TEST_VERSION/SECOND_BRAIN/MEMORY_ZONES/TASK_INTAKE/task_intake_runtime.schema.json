{
  "schema_id": "task_intake_runtime_v0.3",
  "title": "TaskIntakeRuntime",
  "description": "V0.3 runtime schema for interactive task intake. Rule-based only, no LLM, no agent API.",
  "type": "object",
  "required": ["task_id", "created_at", "status", "source_text"],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^TI-[0-9]{8}-[0-9]{6}-[0-9]{3}$",
      "description": "e.g. TI-20260516-143022-001"
    },
    "created_at": {"type": "string", "format": "date-time"},
    "status": {
      "type": "string",
      "enum": ["DRAFT", "TASK_ACCEPTED", "NEEDS_OWNER_CLARIFICATION", "READY_FOR_PLAN", "BLOCKED"]
    },
    "source_text": {"type": "string"},
    "owner_goal": {"type": ["string", "null"]},
    "priority": {"type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"], "default": "MEDIUM"},
    "tags": {"type": "array", "items": {"type": "string"}},
    "relevant_memory_zones": {"type": "array", "items": {"type": "string"}},
    "created_by": {"type": "string", "default": "OWNER_INTERACTIVE"},
    "runtime_mode": {
      "type": "string",
      "enum": ["PROTOTYPE_INTERACTIVE", "RULE_BASED_ONLY"],
      "default": "PROTOTYPE_INTERACTIVE"
    },
    "receipts": {"type": "array", "items": {"type": "string"}},
    "links": {"type": "array", "items": {"type": "string"}},
    "next_expected_action": {"type": ["string", "null"]},
    "seed_demo": {"type": "boolean", "default": false}
  }
}
