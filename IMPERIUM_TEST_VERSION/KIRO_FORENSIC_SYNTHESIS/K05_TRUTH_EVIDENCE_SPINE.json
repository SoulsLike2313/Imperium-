  "truth_semantics": {
    "PASS": {
      "definition": "All checks passed with fresh evidence",
      "requirements": [
        "evidence_path exists and readable",
        "evidence_timestamp within freshness_threshold",
        "no blockers in evidence",
        "exit_code == 0 for all commands"
      ],
      "forbidden_if": ["any FAIL", "any UNKNOWN", "stale evidence", "missing evidence"]
    },
    "PASS_WITH_WARNINGS": {
      "definition": "All critical checks passed, non-critical warnings present",
      "requirements": [
        "all critical checks PASS",
        "warnings documented in evidence",
        "warnings are non-blocking"
      ],
      "forbidden_if": ["any critical FAIL", "undocumented warnings"]
    },
    "PARTIAL": {
      "definition": "Some checks passed, some not run or incomplete",
      "requirements": [
        "at least one check PASS",
        "incomplete checks documented",
        "no false PASS claims"
      ],
      "forbidden_if": ["claiming full coverage"]
    },
    "FAIL": {
      "definition": "One or more checks failed",
      "requirements": [
        "failure evidence captured",
        "failure reason documented",
        "exit_code != 0 or assertion failed"
      ],
      "forbidden_if": ["hiding failures", "downgrading to WARNING"]
    },
    "UNKNOWN": {
      "definition": "Check not run or result indeterminate",
      "requirements": [
        "explicitly marked UNKNOWN",
        "reason documented"
      ],
      "forbidden_if": ["defaulting to PASS", "silent skip"]
    },
    "STALE": {
      "definition": "Evidence exists but exceeds freshness threshold",
      "requirements": [
        "evidence_timestamp older than threshold",
        "STALE flag explicitly set",
        "last_known_status preserved"
      ],
      "forbidden_if": ["claiming fresh", "hiding staleness"]
    },
    "NOT_IMPLEMENTED": {
      "definition": "Feature/check does not exist yet",
      "requirements": [
        "explicitly marked NOT_IMPLEMENTED",
        "no false claims of existence"
      ],
      "forbidden_if": ["claiming PASS", "claiming PARTIAL"]
    }
  },
  
