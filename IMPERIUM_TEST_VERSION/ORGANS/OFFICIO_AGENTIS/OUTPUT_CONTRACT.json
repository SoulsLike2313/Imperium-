{
  "schema_version": "IMPERIUM_OUTPUT_CONTRACT_V0_1",
  "created_at": "2026-05-15T22:00:00+00:00",
  "description": "Defines required structure for agent outputs",
  "required_fields": {
    "task_output": [
      "task_id",
      "timestamp",
      "agent_id",
      "verdict",
      "evidence"
    ],
    "code_change": [
      "file_path",
      "change_type",
      "before_hash",
      "after_hash",
      "reason"
    ],
    "report": [
      "report_type",
      "timestamp",
      "summary",
      "details"
    ]
  },
  "forbidden_outputs": [
    "Unstructured prose without actionable content",
    "Code without tests",
    "Changes without receipts",
    "PASS without evidence",
    "Files outside scope corridor"
  ],
  "output_limits": {
    "max_files_per_task": 10,
    "max_lines_per_file": 500,
    "max_total_lines": 2000,
    "bloat_threshold_percent": 150
  },
  "evidence_requirements": {
    "code_change": ["before_after_diff", "syntax_check", "test_result"],
    "ui_change": ["screenshot_before", "screenshot_after"],
    "config_change": ["validation_result"],
    "script_creation": ["syntax_check", "smoke_test"]
  },
  "receipt_template": {
    "receipt_id": "AUTO-GENERATED",
    "task_id": "FROM_TASK",
    "agent_id": "FROM_AGENT",
    "timestamp": "ISO8601",
    "action": "DESCRIPTION",
    "inputs": ["LIST"],
    "outputs": ["LIST"],
    "verdict": "PASS|FAIL",
    "evidence_paths": ["LIST"],
    "notes": "OPTIONAL"
  }
}
