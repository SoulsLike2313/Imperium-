{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "memory_zone.schema.json",
  "title": "Memory Zone",
  "description": "Schema for IMPERIUM Second Brain memory zone",
  "type": "object",
  "required": ["zone_id", "name", "topic", "sensitivity", "trust_level"],
  "properties": {
    "zone_id": { "type": "string" },
    "name": { "type": "string" },
    "topic": { "type": "string" },
    "scope": { "type": "string" },
    "source": { "type": "string" },
    "sensitivity": { "type": "string", "enum": ["PUBLIC", "INTERNAL", "PRIVATE", "SECRET"] },
    "freshness": { "type": "string", "enum": ["CURRENT", "RECENT", "STALE", "ARCHIVE"] },
    "trust_level": { "type": "string", "enum": ["HIGH", "MEDIUM", "LOW", "UNVERIFIED"] },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_id", "title", "type"],
        "properties": {
          "item_id": { "type": "string" },
          "title": { "type": "string" },
          "content": { "type": "string" },
          "type": { "type": "string", "enum": ["NOTE", "LINK", "FILE", "SNIPPET", "REFERENCE"] },
          "tags": { "type": "array", "items": { "type": "string" } },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "source": { "type": "string" }
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
