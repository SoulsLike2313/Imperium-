{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "IMPERIUM_PORT_RESPONSE_V1",
  "title": "IMPERIUM Port Response V1",
  "type": "object",
  "required": [
    "schema",
    "message_id",
    "response_id",
    "status",
    "payload_path",
    "receipt_path",
    "warnings",
    "blockers"
  ],
  "properties": {
    "schema": {
      "const": "IMPERIUM_PORT_RESPONSE_V1"
    },
    "message_id": {
      "type": "string"
    },
    "response_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "OK",
        "ALLOW",
        "ALLOW_WITH_LIMITATIONS",
        "BLOCK",
        "ERROR"
      ]
    },
    "payload_path": {
      "type": "string"
    },
    "receipt_path": {
      "type": "string"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
