{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "imperium/astronomicon/speculum_stage_review_response.schema.json",
  "title": "Speculum Stage Review Response",
  "type": "object",
  "required": [
    "schema_version",
    "review_id",
    "task_id",
    "stage_review_verdict",
    "stage_atomicity",
    "stage_sequence_risk",
    "missing_preconditions",
    "missing_checks",
    "missing_receipts",
    "forbidden_operations",
    "owner_gates",
    "fake_green_risk",
    "continue_stop_rules",
    "bundle_requirements",
    "stage_metric_updates",
    "final_recommendation",
    "response_status"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "string" },
    "review_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "stage_review_verdict": { "type": "string" },
    "stage_atomicity": { "type": ["string", "number", "integer", "null"] },
    "stage_sequence_risk": { "type": ["string", "number", "integer", "null"] },
    "missing_preconditions": { "type": "array", "items": { "type": "string" } },
    "missing_checks": { "type": "array", "items": { "type": "string" } },
    "missing_receipts": { "type": "array", "items": { "type": "string" } },
    "forbidden_operations": { "type": "array", "items": { "type": "string" } },
    "owner_gates": { "type": "array", "items": { "type": "string" } },
    "fake_green_risk": { "type": ["string", "number", "integer", "null"] },
    "continue_stop_rules": { "type": "array", "items": { "type": "string" } },
    "bundle_requirements": { "type": "array", "items": { "type": "string" } },
    "stage_metric_updates": { "type": "object", "additionalProperties": true },
    "final_recommendation": { "type": "string" },
    "advisory_notes": { "type": "string" },
    "response_status": { "type": "string" }
  }
}
