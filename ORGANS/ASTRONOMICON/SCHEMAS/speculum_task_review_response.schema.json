{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "imperium/astronomicon/speculum_task_review_response.schema.json",
  "title": "Speculum Task Review Response",
  "type": "object",
  "required": [
    "schema_version",
    "review_id",
    "task_candidate_id",
    "review_verdict",
    "stage_split_ready",
    "hidden_failure_modes",
    "missing_constraints",
    "scope_corrections",
    "forbidden_files_zones",
    "required_checkers",
    "required_receipts",
    "owner_decision_points",
    "metric_updates",
    "reject_or_delay_reasons",
    "minimal_viable_boundary",
    "final_recommendation",
    "response_status"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "string" },
    "review_id": { "type": "string", "minLength": 1 },
    "task_candidate_id": { "type": "string", "minLength": 1 },
    "review_verdict": { "type": "string" },
    "stage_split_ready": { "type": ["boolean", "string"] },
    "hidden_failure_modes": { "type": "array", "items": { "type": "string" } },
    "missing_constraints": { "type": "array", "items": { "type": "string" } },
    "scope_corrections": { "type": "array", "items": { "type": "string" } },
    "forbidden_files_zones": { "type": "array", "items": { "type": "string" } },
    "required_checkers": { "type": "array", "items": { "type": "string" } },
    "required_receipts": { "type": "array", "items": { "type": "string" } },
    "owner_decision_points": { "type": "array", "items": { "type": "string" } },
    "metric_updates": { "type": "object", "additionalProperties": true },
    "reject_or_delay_reasons": { "type": "array", "items": { "type": "string" } },
    "minimal_viable_boundary": { "type": "string" },
    "final_recommendation": { "type": "string" },
    "advisory_notes": { "type": "string" },
    "response_status": { "type": "string" }
  }
}
