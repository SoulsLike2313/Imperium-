{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "imperium/astronomicon/stage.schema.json",
  "title": "Astronomicon Stage",
  "type": "object",
  "required": [
    "schema_version",
    "stage_id",
    "task_id",
    "sequence",
    "purpose",
    "inputs",
    "outputs",
    "allowed_operations",
    "forbidden_operations",
    "files_allowed",
    "files_forbidden",
    "preconditions",
    "pass_criteria",
    "fail_criteria",
    "checks_required",
    "receipts_required",
    "owner_approval_required",
    "continue_rule",
    "stop_rule",
    "expected_artifacts",
    "administratum_handoff_required",
    "dashboard_status",
    "stage_metrics"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "string" },
    "stage_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "sequence": { "type": "integer", "minimum": 1 },
    "purpose": { "type": "string", "minLength": 1 },
    "inputs": { "type": "array", "items": { "type": "string" } },
    "outputs": { "type": "array", "items": { "type": "string" } },
    "allowed_operations": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "forbidden_operations": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "files_allowed": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "files_forbidden": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "preconditions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "pass_criteria": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "fail_criteria": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "checks_required": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "receipts_required": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "owner_approval_required": { "type": "boolean" },
    "continue_rule": { "type": "string", "minLength": 1 },
    "stop_rule": { "type": "string", "minLength": 1 },
    "expected_artifacts": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "administratum_handoff_required": { "type": "boolean" },
    "dashboard_status": { "type": "string" },
    "stage_metrics": {
      "type": "object",
      "required": [
        "stage_atomicity",
        "stage_reversibility",
        "files_touched_count",
        "checker_availability",
        "receipt_availability",
        "owner_gate_need",
        "destructive_action_risk",
        "dependency_readiness",
        "expected_runtime",
        "output_artifact_clarity",
        "rollback_clarity",
        "evidence_completeness",
        "next_stage_dependency",
        "agent_context_required",
        "failure_recovery_path",
        "bundle_complexity",
        "administratum_acceptance_complexity"
      ],
      "additionalProperties": true,
      "properties": {
        "stage_atomicity": { "type": ["string", "number", "integer", "null"] },
        "stage_reversibility": { "type": ["string", "number", "integer", "null"] },
        "files_touched_count": { "type": ["string", "number", "integer", "null"] },
        "checker_availability": { "type": ["string", "number", "integer", "null"] },
        "receipt_availability": { "type": ["string", "number", "integer", "null"] },
        "owner_gate_need": { "type": ["string", "number", "integer", "null"] },
        "destructive_action_risk": { "type": ["string", "number", "integer", "null"] },
        "dependency_readiness": { "type": ["string", "number", "integer", "null"] },
        "expected_runtime": { "type": ["string", "number", "integer", "null"] },
        "output_artifact_clarity": { "type": ["string", "number", "integer", "null"] },
        "rollback_clarity": { "type": ["string", "number", "integer", "null"] },
        "evidence_completeness": { "type": ["string", "number", "integer", "null"] },
        "next_stage_dependency": { "type": ["string", "number", "integer", "null"] },
        "agent_context_required": { "type": ["string", "number", "integer", "null"] },
        "failure_recovery_path": { "type": ["string", "number", "integer", "null"] },
        "bundle_complexity": { "type": ["string", "number", "integer", "null"] },
        "administratum_acceptance_complexity": { "type": ["string", "number", "integer", "null"] }
      }
    }
  }
}
