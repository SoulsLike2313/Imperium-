{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "imperium/astronomicon/general_task.schema.json",
  "title": "Astronomicon General Task",
  "type": "object",
  "required": [
    "schema_version",
    "general_task_id",
    "title",
    "owner_goal",
    "desired_outcome",
    "scope_in",
    "scope_out",
    "constraints",
    "forbidden_actions",
    "known_context",
    "unknowns",
    "success_criteria",
    "failure_criteria",
    "expected_deliverables",
    "target_organs",
    "risk_level",
    "owner_approval_points",
    "decomposition_hints",
    "local_task_candidate_count_hint",
    "priority",
    "dependencies",
    "local_private_boundary_notes",
    "dashboard_display_title",
    "tags",
    "created_by",
    "created_at",
    "current_status",
    "body_sections"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "string" },
    "general_task_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "owner_goal": { "type": "string", "minLength": 1 },
    "desired_outcome": { "type": "string", "minLength": 1 },
    "scope_in": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "scope_out": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "constraints": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "forbidden_actions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "known_context": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "unknowns": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "success_criteria": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "failure_criteria": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "expected_deliverables": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "target_organs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "risk_level": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
    "owner_approval_points": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "decomposition_hints": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "local_task_candidate_count_hint": { "type": "integer", "minimum": 1 },
    "priority": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
    "dependencies": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "local_private_boundary_notes": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "dashboard_display_title": { "type": "string", "minLength": 1 },
    "tags": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "created_by": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "current_status": { "type": "string" },
    "body_sections": {
      "type": "object",
      "required": [
        "Background",
        "Detailed Owner Intent",
        "Known Context",
        "Unknowns and Questions",
        "Notes for Decomposition",
        "Notes for Speculum",
        "Notes for Dashboard Display"
      ],
      "additionalProperties": true,
      "properties": {
        "Background": { "type": "string", "minLength": 1 },
        "Detailed Owner Intent": { "type": "string", "minLength": 1 },
        "Known Context": { "type": "string", "minLength": 1 },
        "Unknowns and Questions": { "type": "string", "minLength": 1 },
        "Notes for Decomposition": { "type": "string", "minLength": 1 },
        "Notes for Speculum": { "type": "string", "minLength": 1 },
        "Notes for Dashboard Display": { "type": "string", "minLength": 1 }
      }
    }
  }
}
