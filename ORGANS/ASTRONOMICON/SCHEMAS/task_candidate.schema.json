{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "imperium/astronomicon/task_candidate.schema.json",
  "title": "Astronomicon Task Candidate",
  "type": "object",
  "required": [
    "schema_version",
    "task_candidate_id",
    "general_task_id",
    "title",
    "local_task_summary",
    "scope_in",
    "scope_out",
    "target_organ",
    "files_likely_touched",
    "dependencies",
    "unresolved_questions",
    "metric_zones",
    "speculum_review_fields",
    "speculum_review_status",
    "modernized",
    "registered",
    "current_status"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "string" },
    "task_candidate_id": { "type": "string", "minLength": 1 },
    "general_task_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "local_task_summary": { "type": "string", "minLength": 1 },
    "scope_in": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "scope_out": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "target_organ": { "type": "string", "minLength": 1 },
    "files_likely_touched": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "unresolved_questions": { "type": "array", "items": { "type": "string" } },
    "speculum_review_fields": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "speculum_review_status": { "type": "string" },
    "modernized": { "type": "boolean" },
    "registered": { "type": "boolean" },
    "current_status": { "type": "string" },
    "metric_zones": {
      "type": "object",
      "required": [
        "scope_size",
        "touched_zones_count",
        "file_change_risk",
        "private_context_dependency",
        "external_tool_dependency",
        "ui_dependency",
        "schema_dependency",
        "script_dependency",
        "dashboard_dependency",
        "receipt_requirement_level",
        "checker_requirement_level",
        "owner_gate_level",
        "rollback_complexity",
        "artifact_complexity",
        "stage_count_estimate",
        "agent_context_load",
        "ambiguity_level",
        "dependency_count",
        "blocker_probability",
        "fake_green_risk",
        "stale_data_risk",
        "warning_noise_risk",
        "local_vs_repo_boundary_risk",
        "vm2_need_level",
        "commit_batching_suitability",
        "review_required_by_speculum"
      ],
      "additionalProperties": true,
      "properties": {
        "scope_size": { "type": ["string", "number", "integer", "null"] },
        "touched_zones_count": { "type": ["string", "number", "integer", "null"] },
        "file_change_risk": { "type": ["string", "number", "integer", "null"] },
        "private_context_dependency": { "type": ["string", "number", "integer", "null"] },
        "external_tool_dependency": { "type": ["string", "number", "integer", "null"] },
        "ui_dependency": { "type": ["string", "number", "integer", "null"] },
        "schema_dependency": { "type": ["string", "number", "integer", "null"] },
        "script_dependency": { "type": ["string", "number", "integer", "null"] },
        "dashboard_dependency": { "type": ["string", "number", "integer", "null"] },
        "receipt_requirement_level": { "type": ["string", "number", "integer", "null"] },
        "checker_requirement_level": { "type": ["string", "number", "integer", "null"] },
        "owner_gate_level": { "type": ["string", "number", "integer", "null"] },
        "rollback_complexity": { "type": ["string", "number", "integer", "null"] },
        "artifact_complexity": { "type": ["string", "number", "integer", "null"] },
        "stage_count_estimate": { "type": ["string", "number", "integer", "null"] },
        "agent_context_load": { "type": ["string", "number", "integer", "null"] },
        "ambiguity_level": { "type": ["string", "number", "integer", "null"] },
        "dependency_count": { "type": ["string", "number", "integer", "null"] },
        "blocker_probability": { "type": ["string", "number", "integer", "null"] },
        "fake_green_risk": { "type": ["string", "number", "integer", "null"] },
        "stale_data_risk": { "type": ["string", "number", "integer", "null"] },
        "warning_noise_risk": { "type": ["string", "number", "integer", "null"] },
        "local_vs_repo_boundary_risk": { "type": ["string", "number", "integer", "null"] },
        "vm2_need_level": { "type": ["string", "number", "integer", "null"] },
        "commit_batching_suitability": { "type": ["string", "number", "integer", "null"] },
        "review_required_by_speculum": { "type": ["string", "number", "integer", "null"] }
      }
    }
  }
}
