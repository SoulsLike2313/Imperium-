{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "schema_version",
    "violation_id",
    "severity",
    "source",
    "description",
    "provenance",
    "timestamp_utc"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "provenance": {
      "type": "object"
    },
    "timestamp_utc": {
      "type": "string"
    },
    "violation_id": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "source": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "evidence_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
