{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "verdict",
    "allow_execution",
    "reasons",
    "evidence_paths",
    "provenance",
    "timestamp_utc"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "provenance": {
      "type": "object"
    },
    "timestamp_utc": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "ALLOW",
        "BLOCK"
      ]
    },
    "allow_execution": {
      "type": "boolean"
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
