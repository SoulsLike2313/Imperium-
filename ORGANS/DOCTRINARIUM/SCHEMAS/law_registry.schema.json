{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "schema_version",
    "registry_id",
    "laws",
    "provenance",
    "timestamp_utc"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "provenance": {
      "type": "object"
    },
    "timestamp_utc": {
      "type": "string"
    },
    "registry_id": {
      "type": "string"
    },
    "laws": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "integrity_status": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
