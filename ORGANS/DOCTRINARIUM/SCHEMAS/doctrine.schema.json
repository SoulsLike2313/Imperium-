{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "schema_version",
    "doctrine_id",
    "title",
    "status",
    "provenance",
    "timestamp_utc"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "provenance": {
      "type": "object"
    },
    "timestamp_utc": {
      "type": "string"
    },
    "doctrine_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "candidate",
        "active",
        "disabled",
        "retired"
      ]
    },
    "content": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
