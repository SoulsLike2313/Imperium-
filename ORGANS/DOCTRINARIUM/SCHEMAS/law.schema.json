{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "schema_version",
    "law_id",
    "title",
    "status",
    "description",
    "provenance",
    "timestamp_utc"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "provenance": {
      "type": "object"
    },
    "timestamp_utc": {
      "type": "string"
    },
    "law_id": {
      "type": "string",
      "pattern": "^LAW-[0-9]{3}$"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "candidate",
        "active",
        "disabled",
        "retired"
      ]
    },
    "description": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
