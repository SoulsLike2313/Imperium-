{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "officio_agent_test_case.schema.json",
  "title": "Officio Agent Test Case v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "test_id",
    "role_id",
    "mode_id",
    "scenario",
    "input_summary",
    "expected_behavior",
    "pass_criteria",
    "fail_criteria",
    "evidence_required",
    "risk_covered"
  ],
  "properties": {
    "test_id": {
      "type": "string",
      "minLength": 1
    },
    "role_id": {
      "type": "string",
      "enum": [
        "SERVITOR",
        "LOGOS_PRIME",
        "LOGOS_SPECULUM",
        "ADVISOR_SERVITOR"
      ]
    },
    "mode_id": {
      "type": "string",
      "minLength": 1
    },
    "scenario": {
      "type": "string",
      "minLength": 1
    },
    "input_summary": {
      "type": "string",
      "minLength": 1
    },
    "expected_behavior": {
      "type": "string",
      "minLength": 1
    },
    "pass_criteria": {
      "type": "string",
      "minLength": 1
    },
    "fail_criteria": {
      "type": "string",
      "minLength": 1
    },
    "evidence_required": {
      "type": "string",
      "minLength": 1
    },
    "risk_covered": {
      "type": "string",
      "minLength": 1
    }
  }
}
