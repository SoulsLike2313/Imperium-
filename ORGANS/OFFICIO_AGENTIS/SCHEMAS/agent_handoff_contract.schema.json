{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "officio_agent_handoff_contract.schema.json",
  "title": "Officio Agent Handoff Contract v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "handoff_id",
    "from_role_id",
    "to_role_id",
    "task_id",
    "summary",
    "required_artifacts",
    "open_risks",
    "next_actions"
  ],
  "properties": {
    "handoff_id": {
      "type": "string",
      "minLength": 1
    },
    "from_role_id": {
      "type": "string",
      "minLength": 1
    },
    "to_role_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "required_artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "open_risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
