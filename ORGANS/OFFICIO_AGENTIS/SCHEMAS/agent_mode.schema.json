{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "officio_agent_mode.schema.json",
  "title": "Officio Agent Modes v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "role_id",
    "modes",
    "allowed_transitions"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "role_id": {
      "type": "string",
      "minLength": 1
    },
    "modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "mode_id",
          "purpose",
          "allowed_actions",
          "forbidden_actions",
          "entry_conditions",
          "exit_conditions",
          "stop_conditions"
        ],
        "properties": {
          "mode_id": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "allowed_actions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "forbidden_actions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "entry_conditions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "exit_conditions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "stop_conditions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "allowed_transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "from_mode",
          "to_mode",
          "condition"
        ],
        "properties": {
          "from_mode": {
            "type": "string",
            "minLength": 1
          },
          "to_mode": {
            "type": "string",
            "minLength": 1
          },
          "condition": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
