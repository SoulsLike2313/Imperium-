{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "imperium.receipt.v0_1",
  "title": "IMPERIUM Generic Receipt v0.1",
  "type": "object",
  "required": [
    "schema_version",
    "receipt_id",
    "receipt_type",
    "task_id",
    "stage_id",
    "run_id",
    "issuer",
    "created_at_utc",
    "command",
    "inputs",
    "outputs",
    "verdict",
    "warnings",
    "blockers",
    "evidence_paths",
    "git_truth_ref"
  ],
  "properties": {
    "schema_version": {
      "const": "imperium.receipt.v0_1"
    },
    "receipt_id": {
      "type": "string",
      "minLength": 1
    },
    "receipt_type": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "stage_id": {
      "type": ["string", "null"]
    },
    "run_id": {
      "type": ["string", "null"]
    },
    "issuer": {
      "type": "string",
      "minLength": 1
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "command": {
      "type": ["string", "null"]
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verdict": {
      "type": "string",
      "enum": [
        "PASS",
        "PASS_WITH_WARNINGS",
        "DEGRADED",
        "BLOCKED",
        "FAIL",
        "CAN_COMMIT",
        "CANNOT_COMMIT",
        "NEEDS_OWNER_DECISION"
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "git_truth_ref": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": true
}
