{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IMPERIUM Warning Stale Baseline v0.1",
  "type": "object",
  "required": [
    "schema_version",
    "updated_at_utc",
    "task_id",
    "baseline_head",
    "categories",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "imperium.warning_stale_baseline.v0_1"
    },
    "updated_at_utc": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "baseline_head": {
      "type": "string",
      "minLength": 40,
      "maxLength": 40
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "category_id",
          "description",
          "status"
        ],
        "properties": {
          "category_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["PROVEN", "WARNING", "UNKNOWN", "BLOCKED"]
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["PROVEN", "WARNING", "UNKNOWN", "BLOCKED"]
    }
  }
}
