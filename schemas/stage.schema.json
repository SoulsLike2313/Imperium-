{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "imperium.stage.v0_1",
  "title": "IMPERIUM Stage v0.1",
  "type": "object",
  "required": [
    "schema_version",
    "stage_id",
    "parent_task_id",
    "order",
    "title",
    "purpose",
    "dependencies",
    "inputs",
    "expected_outputs",
    "allowed_paths",
    "forbidden_paths",
    "pass_criteria",
    "owner_gate_required",
    "status"
  ],
  "properties": {
    "schema_version": {
      "const": "imperium.stage.v0_1"
    },
    "stage_id": {
      "type": "string",
      "minLength": 1
    },
    "parent_task_id": {
      "type": "string",
      "minLength": 1
    },
    "order": {
      "type": "integer",
      "minimum": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expected_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "allowed_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pass_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "stage_pass_criteria.schema.json"
      }
    },
    "owner_gate_required": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
