{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "imperium.stage_pass_criteria.v0_1",
  "title": "IMPERIUM Stage Pass Criteria v0.1",
  "type": "object",
  "required": [
    "criteria_id",
    "statement",
    "verification_method",
    "expected_evidence",
    "blocking",
    "owner_approval_required"
  ],
  "properties": {
    "criteria_id": {
      "type": "string",
      "minLength": 1
    },
    "statement": {
      "type": "string",
      "minLength": 1
    },
    "verification_method": {
      "type": "string",
      "minLength": 1
    },
    "expected_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "blocking": {
      "type": "boolean"
    },
    "owner_approval_required": {
      "type": "boolean"
    }
  },
  "additionalProperties": true
}
