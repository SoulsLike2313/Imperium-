{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "administratum_task_bundle_manifest.schema.json",
  "title": "Administratum Task Bundle Manifest v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "status",
    "bundle_root",
    "bundle_task_dir",
    "created_utc",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "administratum_task_bundle_manifest_v0_1"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "BUNDLED"
      ]
    },
    "bundle_root": {
      "type": "string",
      "minLength": 1
    },
    "bundle_task_dir": {
      "type": "string",
      "minLength": 1
    },
    "created_utc": {
      "type": "string",
      "format": "date-time"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_path",
          "dest_path",
          "sha256"
        ],
        "properties": {
          "source_path": {
            "type": "string",
            "minLength": 1
          },
          "dest_path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
