{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "imperium.technical_review_input.v0_1",
  "title": "IMPERIUM Technical Review Input v0.1",
  "type": "object",
  "required": [
    "input_id",
    "source_type",
    "source_path",
    "canonicality",
    "purpose",
    "status",
    "used_for"
  ],
  "properties": {
    "input_id": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "enum": [
        "external_research_advisory",
        "hard_red_team_architecture_review",
        "engineering_audit",
        "dependency_review",
        "security_boundary_review",
        "implementation_risk_review",
        "future_improvement_recommendations",
        "owner_uploaded_reference"
      ]
    },
    "source_path": {
      "type": "string",
      "minLength": 1
    },
    "source_git_ref": {
      "type": "string"
    },
    "canonicality": {
      "type": "string",
      "enum": [
        "ADVISORY_ONLY",
        "NON_CANON_UNTIL_RECONCILED",
        "OWNER_APPROVED_REFERENCE",
        "CANON_AFTER_FORMALIZATION"
      ]
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "reviewer_role": {
      "type": "string"
    },
    "used_for": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
