{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "imperium.bundle_manifest.v0_1",
  "title": "IMPERIUM Worker Bundle Manifest v0.1",
  "type": "object",
  "required": [
    "schema_version",
    "bundle_id",
    "task_id",
    "stage_id",
    "run_id",
    "builder",
    "created_at_utc",
    "source_git_truth",
    "target_git_truth",
    "route_truth_ref",
    "repo_files",
    "evidence_files",
    "receipt_files",
    "sha256",
    "scope",
    "checks",
    "declared_verdict",
    "no_fake_green_statement"
  ],
  "properties": {
    "schema_version": {
      "const": "imperium.bundle_manifest.v0_1"
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "stage_id": {
      "type": ["string", "null"]
    },
    "run_id": {
      "type": ["string", "null"]
    },
    "builder": {
      "type": "object",
      "required": ["contour", "agent_role"],
      "properties": {
        "contour": {
          "type": "string",
          "minLength": 1
        },
        "agent_role": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "source_git_truth": {
      "type": "object",
      "required": ["head", "commit_count", "tree_url"],
      "properties": {
        "head": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "origin_master": {
          "type": "string"
        },
        "commit_count": {
          "type": ["integer", "string"]
        },
        "latest_commit_oneline": {
          "type": "string"
        },
        "tree_url": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "target_git_truth": {
      "type": ["object", "null"]
    },
    "route_truth_ref": {
      "type": "string",
      "minLength": 1
    },
    "repo_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        },
        "additionalProperties": true
      }
    },
    "evidence_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        },
        "additionalProperties": true
      }
    },
    "receipt_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        },
        "additionalProperties": true
      }
    },
    "sha256": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      }
    },
    "scope": {
      "type": "object",
      "required": ["allowed_paths", "forbidden_paths_touched"],
      "properties": {
        "allowed_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden_paths_touched": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "declared_verdict": {
      "type": "string",
      "enum": ["PASS", "PASS_WITH_WARNINGS", "DEGRADED", "BLOCKED", "FAIL"]
    },
    "no_fake_green_statement": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
