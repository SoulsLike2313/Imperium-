{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Imperium Bundle Route Registry v0.1",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "canonical_vm2_outbox",
    "canonical_pc_inbox",
    "legacy_scan_dirs",
    "source_priority_order",
    "fetch_latest_policy",
    "dedupe_policy",
    "owner_rule"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "task_id": {"type": "string"},
    "status": {"type": "string"},
    "created_at_utc": {"type": "string"},
    "repo_truth_at_creation": {"type": "object"},
    "canonical_vm2_outbox": {"type": "string"},
    "canonical_pc_inbox": {"type": "string"},
    "legacy_scan_dirs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "source_priority_order": {
      "type": "array",
      "items": {"type": "string"}
    },
    "fetch_latest_policy": {"type": "object"},
    "dedupe_policy": {"type": "object"},
    "owner_rule": {"type": "string"},
    "notes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "act5_execution_ready": {"type": "boolean"},
    "ready_for_agent_status": {"type": "boolean"}
  }
}
