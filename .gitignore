# IMPERIUM ignore rules
# We track everything except the old bulk archive.

/ARCHIVE/

# Heavy legacy observed repo copies.
# They are known sources, but must not be committed to GitHub main.
OBSERVED/THRONE_REPO_COPY/*.tar.gz
OBSERVED/VM3_REPO_COPY/*.tar.gz

# Generated artifact extraction/check mirrors.
# These are not live source. They can contain extremely deep paths.
ARTIFACTS/**/FINAL_BUNDLE_EXTRACT_CHECK/
ARTIFACTS/**/BUNDLE_EXTRACT_CHECK/
ARTIFACTS/**/EXTRACT_CHECK/
ARTIFACTS/**/extract/INPUT_ROOT/
ARTIFACTS/**/extract/OUTPUT_ROOT/
