# IMPERIUM ignore rules
# Public Git stores safe source, docs, indexes, receipts, and public state.
# Local/private/heavy/generated sources stay out of Git.

# Experimental test version - NEVER commit
/IMPERIUM_TEST_VERSION/

/ARCHIVE/
/SSH_COMMAND_LIBRARY/
/BUNDLES_LOCAL/
/PRIVATE_CONTEXT_LOCAL/
/RUNTIME_LOCAL/
/.imperium_runtime/

OBSERVED/THRONE_REPO_COPY/*.tar.gz
OBSERVED/VM3_REPO_COPY/*.tar.gz

ARTIFACTS/**/FINAL_BUNDLE_EXTRACT_CHECK/
ARTIFACTS/**/BUNDLE_EXTRACT_CHECK/
ARTIFACTS/**/EXTRACT_CHECK/
ARTIFACTS/**/extract/INPUT_ROOT/
ARTIFACTS/**/extract/OUTPUT_ROOT/

.env
.env.*
*.local.json
*.local.yaml
*.pem
*.ppk
*.key
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
known_hosts
authorized_keys
credentials*
secrets*
tokens*
cookies*
sessions*
*password*
*credential*
*token*
*secret*

__pycache__/
*.pyc
node_modules/
.cache/
tmp/
TEMP/
runtime/
sessions/

/CHAT_COMPILATIONS_LOCAL/

# Manual worktree cleanup rules
# Task zip capsules are local transfer/evidence packages, not Git public memory.
ARTIFACTS/**/00_TASK.zip
ARTIFACTS/**/*.zip

# Screenshots or archives mentioning SSH_COMMAND_LIBRARY are local/manual-review evidence.
ARTIFACTS/**/*SSH_COMMAND_LIBRARY*.png
ARTIFACTS/**/*SSH_COMMAND_LIBRARY*.zip
EXPLORER/SCREENSHOTS/**/*SSH_COMMAND_LIBRARY*.png
EXPLORER/SCREENSHOTS/**/*SSH_COMMAND_LIBRARY*.zip

# Local observed repository copies and dashboard backups.
/OBSERVED/THRONE_REPO_COPY/
/OBSERVED/VM3_REPO_COPY/
/ORGANS/ADMINISTRATUM/UTILITY/_BACKUPS/

# Manual cleanup working logs.
/CURRENT_STATE/MANUAL_WORKTREE_CLEANUP_*/
# IMPERIUM local transfer inbox/outbox
/INBOX/
/OUTBOX/

# Local external audit working output
AUDIT_OUTPUT/

# IMPERIUM generated continuity packs / local evidence
ORGANS/ADMINISTRATUM/CONTINUITY/PACKS/
